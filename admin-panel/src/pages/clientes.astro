---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import GestorClientes from '../components/clientes/GestorClientes';
---

<DashboardLayout>
  <div class="space-y-6">
    <div>
      <h2 class="text-xl font-semibold text-text-primary">Administración de Clientes</h2>
      <p class="text-sm text-text-secondary">Gestiona las empresas (tenants) registradas y sus módulos contratados.</p>
    </div>

    <GestorClientes client:load />
  </div>
</DashboardLayout>
