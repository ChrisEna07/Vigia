---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ListaNovedades from '../components/novedades/ListaNovedades';
---

<DashboardLayout>
  <div class="space-y-6">
    <div>
      <h2 class="text-xl font-semibold text-text-primary">Novedades y Reportes</h2>
      <p class="text-sm text-text-secondary">Historial de incidencias y reportes enviados por los vigilantes durante su turno.</p>
    </div>

    <ListaNovedades client:load />
  </div>
</DashboardLayout>
