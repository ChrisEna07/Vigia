---
export interface Props {
  variant?: 'ingreso' | 'salida';
}

const { variant = 'ingreso' } = Astro.props;
const classes = variant === 'ingreso'
  ? 'bg-accent/15 text-accent-bright border border-accent/30'
  : 'bg-danger/15 text-danger border border-danger/30';
---

<span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wide ${classes}`}>
  {variant === 'ingreso' ? 'INGRESO' : 'SALIDA'}
</span>
